[0.005715, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[?1h\u001b=\u001b[H\u001b[2J\u001b[?12l\u001b[?25h\u001b[?1000l\u001b[?1002l\u001b[?1003l\u001b[?1006l\u001b[?1005l\u001b[?2004h\u001b(B\u001b[m\u001b[?12l\u001b[?25h\u001b[?1006l\u001b[?1000l\u001b[?1002l\u001b[?1003l\u001b[1;1H\u001b[1;45r\u001b[c\u001b[>c\u001b[>q\u001b]10;?\u001b\\\u001b]11;?\u001b\\\u001b[45;1H\u001b[?25l"]
[0.006263, "o", "\u001b[H                                                                                                                                                              \u001b[K\r\n  \u001b[38;5;173m\u001b[1m🍳  enplace  \u001b(B\u001b[m\u001b[38;5;138m\u001b[1m/\u001b(B\u001b[m  \u001b[38;5;144mOriginal NESTLÉ® TOLL HOUSE® Chocolate Chip Cookies\u001b[39m                                       \u001b[38;5;138m🔍 / search\u001b[39m   \u001b[38;5;138m⚙ m manage\u001b[39m   \u001b[38;5;138m🏠 h home\u001b[39m   \u001b[38;5;138m🚪 q quit\u001b[39m  \u001b[K\r\n                                                                                                                                                              \u001b[K\u001b[38;5;236m\r\n──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\u001b[K\r\n\u001b[K\u001b[38;5;173m\u001b[1m\r\nOriginal NESTLÉ® TOLL HOUSE® Chocolate Chip Cookies\u001b(B\u001b[m                                                 \u001b[K\u001b[38;5;138m\r\nCook 11m  ·  Serves 60 cookies\u001b[39m\u001b[K\u001b[48;5;173m\r\n \u001b[38;5;231mdessert\u001b[39m \u001b[49m \u001b[48;5;108m \u001b[38;5;231mbake\u001b[39m \u001b[49m \u001b[48;5;103m \u001b[38;5;231mamerican\u001b[39m \u001b[49m \u001b[K\r\n\u001b[K\u001b[38;5;144m\u001b[7m\r\nThe classic chocolate chip cookie recipe featuring crispy edges and gooey centers made with NESTLÉ®\u001b(B\u001b[m \u001b[K\u001b[38;5;144m\u001b[7m\r\nTOLL HOUSE® Semi-Sweet Chocolate Morsels. This versatile recipe is easy to prepare and perfect for\u001b(B\u001b[m  \u001b[K\u001b[38;5;144m\u001b[7m\r\nany occasion.\u001b(B\u001b[m                                                                                       \u001b[K\r\n\u001b[K\r\n           \u001b[K\u001b[38;5;108m\u001b[1m\r\nIngredients\u001b(B\u001b[m\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m2 1/4 cup all-purpose flour\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m1 tsp baking soda\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m1 tsp salt\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m1 cup butter, softened\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m3/4 cup granulated sugar\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m3/4 cup brown sugar, packed\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m1 tsp vanilla extract\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m2 eggs, large\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m2 cup chocolate morsels, semi-sweet\u001b[K\u001b[38;5;138m\r\n  · \u001b[39m1 cup nuts, chopped, optional\u001b[K\r\n\u001b[K\r\n          \u001b[K\u001b[38;5;108m\u001b[1m\r\nDirections\u001b(B\u001b[m\u001b[K\r\n\u001b[K\r\n  \u001b[38;5;252m                                                                                                \u001b[39m\u001b[K\r\n  \u001b[38;5;252m1. Preheat oven to 375°F.                                                                       \u001b[39m\u001b[K\r\n  \u001b[38;5;252m2. Combine flour, baking soda, and salt in small bowl.                                          \u001b[39m\u001b[K\r\n  \u001b[38;5;252m3. Beat butter, granulated sugar, brown sugar, and vanilla extract in large mixer bowl until    \u001b[39m\u001b[K\r\n  \u001b[38;5;252mcreamy.                                                                                         \u001b[39m\u001b[K\r\n  \u001b[38;5;252m4. Add eggs one at a time, beating well after each addition.                                    \u001b[39m\u001b[K\r\n  \u001b[38;5;252m5. Gradually beat in flour mixture.                                                             \u001b[39m\u001b[K\r\n  \u001b[38;5;252m6. Stir in chocolate morsels and nuts.                                                          \u001b[39m\u001b[K\r\n  \u001b[38;5;252m7. Drop by rounded tablespoon onto ungreased baking sheets.                                     \u001b[39m\u001b[K\r\n  \u001b[38;5;252m8. Bake for 9 to 11 minutes or until golden brown.                                              \u001b[39m\u001b[K\r\n  \u001b[38;5;252m9. Cool on baking sheets for 2 minutes; remove to wire racks to cool completely.                \u001b[39m\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\u001b[38;5;236m\r\n──────────────────────────────────────────────────────────────────────────────────────────────────────────────"]
